        <pad_bottom value="10"/>
        <pad_left value="22"/>
        <pad_right value="22"/>
    </style>

    <style name="style_cfg_badge_text_active">
        <text_color value="0xE8620A"/>
        <text_font value="lv_font_montserrat_14"/>
        <text_letter_space value="2"/>
