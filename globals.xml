        <border_color value="0xE8620A"/>
        <border_side value="left"/>
        <radius value="0"/>
    </style>

    <style name="style_cfg_row_inactive">
        <bg_color value="0x0D0D0D"/>
        <border_width value="4"/>
        <border_color value="0x1A1A1A"/>
        <border_side value="left"/>
        <radius value="0"/>
    </style>

    <style name="style_cfg_badge">
        <bg_color value="0x111111"/>
        <border_width value="1"/>
        <border_color value="0x1E1E1E"/>
        <radius value="0"/>
