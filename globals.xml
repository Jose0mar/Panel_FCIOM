        <text_color value="0x323232"/>
        <text_font value="lv_font_montserrat_14"/>
        <text_letter_space value="2"/>
    </style>

    <style name="style_cfg_label_active">
        <text_color value="0xD0D0D0"/>
        <text_font value="lv_font_montserrat_14"/>
        <text_letter_space value="3"/>
    </style>

    <style name="style_cfg_label_inactive">
        <text_color value="0x484848"/>
        <text_font value="lv_font_montserrat_14"/>
        <text_letter_space value="3"/>
