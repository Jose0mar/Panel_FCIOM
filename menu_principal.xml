<?xml version="1.0" encoding="UTF-8"?>
<screen name="menu_principal">

    <!-- ═══════════════════════════════════════════
         FONDO BASE DE LA PANTALLA
    ═══════════════════════════════════════════ -->
    <obj
        x="0" y="0"
        width="1024" height="600"
        styles="style_bg">

        <!-- ═══════════════════════════════════════════
             BARRA LATERAL — 200x600px
        ═══════════════════════════════════════════ -->
        <obj name="sidebar"
            x="0" y="0"
            width="200" height="600"
            styles="style_sidebar">

            <!-- ZONA LOGO — 200x80px -->
            <obj name="logo_zone"
                x="0" y="0"
                width="200" height="80"
                styles="style_header">

                <!-- Barra acento naranja izquierda -->
                <obj name="logo_accent_bar"
                    x="16" y="15"
                    width="4" height="50"
                    bg_color="0xE8620A"
                    radius="2"
                    border_width="0"/>

                <!-- Texto VEH -->
                <label name="logo_text_veh"
                    x="32" y="15"
                    text="VEH"
                    styles="style_nav_label_active"/>

                <!-- Texto CTRL -->
                <label name="logo_text_ctrl"
                    x="32" y="37"
                    text="CTRL"
                    styles="style_nav_label_active"/>

                <!-- Texto versión -->
                <label name="logo_version"
                    x="32" y="62"
                    text="ESP32-P4"
                    styles="style_version"/>
            </obj>

            <!-- ÍTEM NAV 1: INFO VEHÍCULO — activo por defecto -->
            <obj name="nav_item_1"
                x="0" y="80"
                width="200" height="100"
                styles="style_nav_active"
                checkable="true"
                checked="true">

                <!-- Icono carro (representado con texto) -->
                <label name="nav_icon_1"
                    x="0" y="18"
                    width="200"
                    align="top_mid"
                    text="[ CAR ]"
                    styles="style_nav_label_active"/>

                <!-- Label del ítem -->
                <label name="nav_label_1"
                    x="0" y="58"
                    width="200"
                    align="top_mid"
                    text="INFO\nVEHICULO"
                    styles="style_nav_label_active"
                    long_mode="wrap"/>
            </obj>

            <!-- ÍTEM NAV 2: CONFIG SISTEMA — inactivo -->
            <obj name="nav_item_2"
                x="0" y="180"
                width="200" height="100"
                styles="style_nav_inactive">

                <!-- Icono config -->
                <label name="nav_icon_2"
                    x="0" y="18"
                    width="200"
                    align="top_mid"
                    text="[ CFG ]"
                    styles="style_nav_label_inactive"/>

                <!-- Label del ítem -->
                <label name="nav_label_2"
                    x="0" y="58"
                    width="200"
                    align="top_mid"
                    text="CONFIG\nSISTEMA"
                    styles="style_nav_label_inactive"
                    long_mode="wrap"/>
            </obj>

            <!-- FOOTER VERSIÓN -->
            <obj name="sidebar_footer"
                x="0" y="564"
                width="200" height="36"
                styles="style_header">
                <label
                    x="0" y="0"
                    width="200" height="36"
                    align="center"
                    text="LVGL // v1.0"
                    styles="style_version"/>
            </obj>

        </obj>
        <!-- FIN SIDEBAR -->


        <!-- ═══════════════════════════════════════════
             HEADER PRINCIPAL — x=200, 824x60px
        ═══════════════════════════════════════════ -->
        <obj name="header"
            x="200" y="0"
            width="824" height="60"
            styles="style_header">

            <!-- Barra de acento vertical -->
            <obj name="header_accent"
                x="26" y="16"
                width="3" height="28"
                bg_color="0xE8620A"
                border_width="0"
                radius="0"/>

            <!-- Título de sección -->
            <label name="header_title"
                x="41" y="0"
                height="60"
                align_y="center"
                text="INFORMACION DEL VEHICULO"
                styles="style_title"/>

            <!-- Reloj HH:MM -->
            <label name="header_clock"
                x="798" y="8"
                text="--:--"
                styles="style_clock"/>

            <!-- Fecha -->
            <label name="header_date"
                x="798" y="46"
                text="SAB 14 MAR 2026"
                styles="style_date"/>

        </obj>
        <!-- FIN HEADER -->


        <!-- ═══════════════════════════════════════════
             ÁREA DE CONTENIDO — x=200, y=60, 824x540px
             VISTA: INFORMACIÓN DEL VEHÍCULO
        ═══════════════════════════════════════════ -->
        <obj name="content_area"
            x="200" y="60"
            width="824" height="540"
            styles="style_bg"
            pad_all="20">

            <!-- FILA 1 DE TARJETAS -->

            <!-- Tarjeta MARCA -->
            <obj name="card_marca"
                x="20" y="20"
                width="250" height="242"
                styles="style_card"
                pad_left="20" pad_top="22" pad_right="20" pad_bottom="22">

                <label name="card_marca_label"
                    x="20" y="22"
                    text="MARCA"
                    styles="style_card_label"/>

                <label name="card_marca_value"
                    x="20" y="60"
                    text="TOYOTA"
                    styles="style_card_value_accent"/>
            </obj>

            <!-- Tarjeta MODELO -->
            <obj name="card_modelo"
                x="286" y="20"
                width="250" height="242"
                styles="style_card"
                pad_left="20" pad_top="22" pad_right="20" pad_bottom="22">

                <label name="card_modelo_label"
                    x="20" y="22"
                    text="MODELO"
                    styles="style_card_label"/>

                <label name="card_modelo_value"
                    x="20" y="60"
                    text="HILUX 4x4"
                    styles="style_card_value"/>
            </obj>

            <!-- Tarjeta AÑO -->
            <obj name="card_anio"
                x="552" y="20"
                width="250" height="242"
                styles="style_card"
                pad_left="20" pad_top="22" pad_right="20" pad_bottom="22">

                <label name="card_anio_label"
                    x="20" y="22"
                    text="ANNO"
                    styles="style_card_label"/>

                <label name="card_anio_value"
                    x="20" y="60"
                    text="2023"
                    styles="style_card_value"/>
            </obj>

            <!-- FILA 2 DE TARJETAS -->

            <!-- Tarjeta VIN -->
            <obj name="card_vin"
                x="20" y="278"
                width="250" height="242"
                styles="style_card"
                pad_left="20" pad_top="22" pad_right="20" pad_bottom="22">

                <label name="card_vin_label"
                    x="20" y="22"
                    text="N. VIN"
                    styles="style_card_label"/>

                <label name="card_vin_value"
                    x="20" y="60"
                    text="JT3HP10VX07..."
                    styles="style_card_value"/>
            </obj>

            <!-- Tarjeta PLACA -->
            <obj name="card_placa"
                x="286" y="278"
                width="250" height="242"
                styles="style_card"
                pad_left="20" pad_top="22" pad_right="20" pad_bottom="22">

                <label name="card_placa_label"
                    x="20" y="22"
                    text="PLACA"
                    styles="style_card_label"/>

                <label name="card_placa_value"
                    x="20" y="60"
                    text="ABC - 1234"
                    styles="style_card_value"/>
            </obj>

            <!-- Tarjeta ODÓMETRO -->
            <obj name="card_odometro"
                x="552" y="278"
                width="250" height="242"
                styles="style_card"
                pad_left="20" pad_top="22" pad_right="20" pad_bottom="22">

                <label name="card_odometro_label"
                    x="20" y="22"
                    text="ODOMETRO"
                    styles="style_card_label"/>

                <label name="card_odometro_value"
                    x="20" y="60"
                    text="45,230 KM"
                    styles="style_card_value"/>
            </obj>

        </obj>
        <!-- FIN CONTENT AREA -->

    </obj>
    <!-- FIN FONDO BASE -->

</screen>
