<screen>
    <animations>
    </animations>

    <view>

        <!-- FONDO BASE -->
        <lv_obj x="0" y="0" width="1024" height="600"
                style_bg_color="0x070707"
                style_border_width="0"
                style_radius="0">

            <!-- SIDEBAR -->
            <lv_obj x="0" y="0" width="200" height="600"
                    style_bg_color="0x0D0D0D"
                    style_border_width="2"
                    style_border_color="0x191919"
                    style_border_side="LV_BORDER_SIDE_RIGHT"
                    style_radius="0">

                <!-- Barra naranja acento -->
                <lv_obj x="16" y="15" width="4" height="50"
                        style_bg_color="0xE8620A"
                        style_border_width="0"
                        style_radius="2"/>

                <!-- Logo VEH -->
                <lv_label x="32" y="14"
                          text="VEH"
                          style_text_color="0xE8620A"/>

                <!-- Logo CTRL -->
                <lv_label x="32" y="36"
                          text="CTRL"
                          style_text_color="0xE8620A"/>

                <!-- Version -->
                <lv_label x="32" y="60"
                          text="ESP32-P4"
                          style_text_color="0x262626"/>

            </lv_obj>
            <!-- FIN SIDEBAR -->

            <!-- HEADER -->
            <lv_obj x="200" y="0" width="824" height="60"
                    style_bg_color="0x0F0F0F"
                    style_border_width="1"
                    style_border_color="0x191919"
                    style_border_side="LV_BORDER_SIDE_BOTTOM"
                    style_radius="0">

                <!-- Barra acento header -->
                <lv_obj x="26" y="16" width="3" height="28"
                        style_bg_color="0xE8620A"
                        style_border_width="0"
                        style_radius="0"/>

                <!-- Titulo -->
                <lv_label x="41" y="22"
                          text="INFORMACION DEL VEHICULO"
                          style_text_color="0xD0D0D0"/>

            </lv_obj>
            <!-- FIN HEADER -->

            <!-- TARJETA MARCA — solo una para probar -->
            <lv_obj x="220" y="80" width="250" height="120"
                    style_bg_color="0x111111"
                    style_border_width="4"
                    style_border_color="0xE8620A"
                    style_border_side="LV_BORDER_SIDE_LEFT"
                    style_radius="0"
                    style_pad_left="20"
                    style_pad_top="20">

                <lv_label x="0" y="0"
                          text="MARCA"
                          style_text_color="0x3A3A3A"/>

                <lv_label x="0" y="30"
                          text="TOYOTA"
                          style_text_color="0xE8620A"/>

            </lv_obj>

        </lv_obj>
        <!-- FIN FONDO -->

    </view>
</screen>
