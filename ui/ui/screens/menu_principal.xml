<?xml version="1.0" encoding="UTF-8"?>
<screen name="menu_principal">
  <style_sheet>
    <style name="scr_bg">
      <obj>
        <bg_color v="0x070707"/>
        <radius v="0"/>
      </obj>
    </style>
    <style name="sidebar">
      <obj>
        <bg_color v="0x0D0D0D"/>
        <border_width v="2"/>
        <border_color v="0x191919"/>
        <border_side v="LV_BORDER_SIDE_RIGHT"/>
        <radius v="0"/>
      </obj>
    </style>
    <style name="header_style">
      <obj>
        <bg_color v="0x0F0F0F"/>
        <border_width v="1"/>
        <border_color v="0x191919"/>
        <border_side v="LV_BORDER_SIDE_BOTTOM"/>
        <radius v="0"/>
      </obj>
    </style>
    <style name="card_style">
      <obj>
        <bg_color v="0x111111"/>
        <border_width v="4"/>
        <border_color v="0xE8620A"/>
        <border_side v="LV_BORDER_SIDE_LEFT"/>
        <radius v="0"/>
        <pad_top v="22"/>
        <pad_bottom v="22"/>
        <pad_left v="20"/>
        <pad_right v="20"/>
      </obj>
    </style>
  </style_sheet>

  <!-- FONDO BASE -->
  <obj x="0" y="0" width="1024" height="600" styles="scr_bg">

    <!-- SIDEBAR 200x600 -->
    <obj name="sidebar" x="0" y="0" width="200" height="600" styles="sidebar">

      <!-- BARRA ACENTO LOGO -->
      <obj x="16" y="15" width="4" height="50"
           bg_color="0xE8620A" border_width="0" radius="2"/>

      <!-- TEXTO LOGO -->
      <label x="32" y="14" text="VEH"
             text_color="0xE8620A" text_font="lv_font_montserrat_18"/>
      <label x="32" y="36" text="CTRL"
             text_color="0xE8620A" text_font="lv_font_montserrat_18"/>
      <label x="32" y="60" text="ESP32-P4"
             text_color="0x262626" text_font="lv_font_montserrat_10"/>

      <!-- SEPARADOR LOGO -->
      <obj x="0" y="79" width="200" height="1"
           bg_color="0x191919" border_width="0" radius="0"/>

      <!-- NAV ITEM 1 — ACTIVO -->
      <obj name="nav_info" x="0" y="80" width="200" height="100"
           bg_color="0x1A1A1A" border_width="4"
           border_color="0xE8620A" border_side="LV_BORDER_SIDE_LEFT" radius="0">
        <label align="top_mid" y="20" text="[ CAR ]"
               text_color="0xE8620A" text_font="lv_font_montserrat_12"/>
        <label align="top_mid" y="54" text="INFO\nVEHICULO"
               text_color="0xE8620A" text_font="lv_font_montserrat_11"
               long_mode="LV_LABEL_LONG_WRAP" text_align="LV_TEXT_ALIGN_CENTER"
               width="180"/>
      </obj>

      <!-- SEPARADOR -->
      <obj x="0" y="179" width="200" height="1"
           bg_color="0x191919" border_width="0" radius="0"/>

      <!-- NAV ITEM 2 — INACTIVO -->
      <obj name="nav_config" x="0" y="180" width="200" height="100"
           bg_color="0x0D0D0D" border_width="1"
           border_color="0x191919" border_side="LV_BORDER_SIDE_BOTTOM" radius="0">
        <label align="top_mid" y="20" text="[ CFG ]"
               text_color="0x3C3C3C" text_font="lv_font_montserrat_12"/>
        <label align="top_mid" y="54" text="CONFIG\nSISTEMA"
               text_color="0x3C3C3C" text_font="lv_font_montserrat_11"
               long_mode="LV_LABEL_LONG_WRAP" text_align="LV_TEXT_ALIGN_CENTER"
               width="180"/>
      </obj>

      <!-- FOOTER VERSION -->
      <obj x="0" y="564" width="200" height="36"
           bg_color="0x0D0D0D" border_width="1"
           border_color="0x191919" border_side="LV_BORDER_SIDE_TOP" radius="0">
        <label align="center" text="LVGL // v1.0"
               text_color="0x262626" text_font="lv_font_montserrat_10"/>
      </obj>

    </obj>
    <!-- FIN SIDEBAR -->

    <!-- HEADER 824x60 -->
    <obj name="header" x="200" y="0" width="824" height="60" styles="header_style">

      <!-- BARRA ACENTO HEADER -->
      <obj x="26" y="16" width="3" height="28"
           bg_color="0xE8620A" border_width="0" radius="0"/>

      <!-- TITULO -->
      <label x="41" y="20" text="INFORMACION DEL VEHICULO"
             text_color="0xD0D0D0" text_font="lv_font_montserrat_16"/>

      <!-- RELOJ -->
      <label name="lbl_clock" align="right_mid" x="-26" y="-8"
             text="--:--"
             text_color="0xD0D0D0" text_font="lv_font_montserrat_30"/>

      <!-- FECHA -->
      <label name="lbl_date" align="right_mid" x="-26" y="14"
             text="SAB 14 MAR 2026"
             text_color="0x2C2C2C" text_font="lv_font_montserrat_10"/>

    </obj>
    <!-- FIN HEADER -->

    <!-- CONTENT AREA — grilla 3x2 de tarjetas -->
    <obj name="content" x="200" y="60" width="824" height="540"
         bg_color="0x070707" border_width="0" radius="0"
         pad_all="20">

      <!-- FILA 1 -->
      <!-- Tarjeta MARCA -->
      <obj x="0" y="0" width="250" height="242" styles="card_style">
        <label x="0" y="0" text="MARCA"
               text_color="0x3A3A3A" text_font="lv_font_montserrat_12"/>
        <label x="0" y="36" text="TOYOTA"
               text_color="0xE8620A" text_font="lv_font_montserrat_22"/>
      </obj>

      <!-- Tarjeta MODELO -->
      <obj x="266" y="0" width="250" height="242" styles="card_style">
        <label x="0" y="0" text="MODELO"
               text_color="0x3A3A3A" text_font="lv_font_montserrat_12"/>
        <label x="0" y="36" text="HILUX 4x4"
               text_color="0xD0D0D0" text_font="lv_font_montserrat_22"/>
      </obj>

      <!-- Tarjeta AÑO -->
      <obj x="532" y="0" width="250" height="242" styles="card_style">
        <label x="0" y="0" text="ANNO"
               text_color="0x3A3A3A" text_font="lv_font_montserrat_12"/>
        <label x="0" y="36" text="2023"
               text_color="0xD0D0D0" text_font="lv_font_montserrat_22"/>
      </obj>

      <!-- FILA 2 -->
      <!-- Tarjeta VIN -->
      <obj x="0" y="258" width="250" height="242" styles="card_style">
        <label x="0" y="0" text="N. VIN"
               text_color="0x3A3A3A" text_font="lv_font_montserrat_12"/>
        <label x="0" y="36" text="JT3HP10VX07..."
               text_color="0x5A5A5A" text_font="lv_font_montserrat_16"/>
      </obj>

      <!-- Tarjeta PLACA -->
      <obj x="266" y="258" width="250" height="242" styles="card_style">
        <label x="0" y="0" text="PLACA"
               text_color="0x3A3A3A" text_font="lv_font_montserrat_12"/>
        <label x="0" y="36" text="ABC - 1234"
               text_color="0xD0D0D0" text_font="lv_font_montserrat_22"/>
      </obj>

      <!-- Tarjeta ODOMETRO -->
      <obj x="532" y="258" width="250" height="242" styles="card_style">
        <label x="0" y="0" text="ODOMETRO"
               text_color="0x3A3A3A" text_font="lv_font_montserrat_12"/>
        <label x="0" y="36" text="45,230 KM"
               text_color="0xD0D0D0" text_font="lv_font_montserrat_22"/>
      </obj>

    </obj>
    <!-- FIN CONTENT -->

  </obj>
</screen>
